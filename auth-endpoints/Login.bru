meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{host}}/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

vars:pre-request {
  email: brian@api.com
  password: aleluya
}

settings {
  encodeUrl: true
  timeout: 0
}
